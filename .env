# =============================================================================
# GOLDEN BOT — ENVIRONMENT CONFIGURATION
# Status: READY FOR TESTNET TRADING (DRY_RUN=false)
# =============================================================================

# -----------------------------------------------------------------------------
# BOT IDENTITY
# -----------------------------------------------------------------------------
GOLDEN_BOT_NAME=Golden Bot
GOLDEN_BOT_ENV=testnet
GOLDEN_BOT_MARKET=futures
GOLDEN_BOT_DRY_RUN=false

# -----------------------------------------------------------------------------
# EXCHANGE CONNECTION (BINANCE TESTNET)
# -----------------------------------------------------------------------------
GOLDEN_BOT_EXCHANGE=binance

# 🔑 SECRET VARIABLE NAMES (NOT VALUES)
# These tell the bot which environment variables contain your actual keys
GOLDEN_BOT_API_KEY_SECRET=BINANCE_API_KEY
GOLDEN_BOT_API_SECRET_SECRET=BINANCE_API_SECRET
GOLDEN_BOT_RATE_LIMIT=10.0

# 🔐 YOUR ACTUAL TESTNET API CREDENTIALS
# Get keys from: https://testnet.binance.vision/
BINANCE_API_KEY=aQaTgXrqCupwzxydO7BMsaTfDCjYRknuW3jXxFcT6V1ZtUcU0gcRtaueZEN97fai
BINANCE_API_SECRET=W5HuifOY8I4YELzu0kUaoHuNOomWwrFaNCzPNNNf4iJ9ZMdTQxSvc63TslnkYt5Q

# -----------------------------------------------------------------------------
# SECRET MANAGEMENT
# -----------------------------------------------------------------------------
GOLDEN_BOT_SECRET_SOURCE=env
VAULT_ADDR=http://localhost:8200
VAULT_TOKEN=your_vault_token_here
VAULT_MOUNT=secret
AWS_REGION=us-east-1

# -----------------------------------------------------------------------------
# RISK MANAGEMENT (Conservative for Testnet Testing)
# -----------------------------------------------------------------------------
GOLDEN_BOT_MAX_LOSS_USD=50.0
GOLDEN_BOT_MAX_LOSS_PER_TRADE_USD=5.0
GOLDEN_BOT_RISK_PER_TRADE_PCT=0.5
GOLDEN_BOT_MAX_PARALLEL_TRADES=2

# -----------------------------------------------------------------------------
# TRADING PARAMETERS
# -----------------------------------------------------------------------------
GOLDEN_BOT_LEVERAGE=3
GOLDEN_BOT_DEFAULT_TIMEFRAME=15m
GOLDEN_BOT_WATCHLIST=BTCUSDT,ETHUSDT
GOLDEN_BOT_SCORE_GATE=60
GOLDEN_BOT_USE_ML=true

# -----------------------------------------------------------------------------
# WEB DASHBOARD
# -----------------------------------------------------------------------------
GOLDEN_BOT_WEB_PORT=8080
GOLDEN_BOT_WEB_TOKEN=cl_bot
GOLDEN_BOT_DASHBOARD_THEME=dark_blue

# -----------------------------------------------------------------------------
# SECURITY KEYS (Validated)
# -----------------------------------------------------------------------------
# HMAC key for audit log chaining (43 chars, URL-safe base64)
GOLDEN_BOT_AUDIT_KEY=X_w3x4h98qJPNf0RgK49fvQEJgYNI6sNgPauGazJsvw

# Fernet encryption key for file-based secrets (44 chars, ends with =)
