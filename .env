GOLDEN_BOT_GEO_RESTRICTIONS=

# -----------------------------------------------------------------------------
# LOGGING & MONITORING
# -----------------------------------------------------------------------------
GOLDEN_BOT_LOG_LEVEL=INFO
GOLDEN_BOT_AUDIT_LOG_PATH=logs/audit.log
GOLDEN_BOT_PROMETHEUS_PORT=9090

# -----------------------------------------------------------------------------
# INFRASTRUCTURE (For Future Phases)
# -----------------------------------------------------------------------------
REDIS_URL=redis://localhost:6379/0
DATABASE_URL=postgresql://botuser:botpass@localhost:5432/goldenbot
MLFLOW_TRACKING_URI=http://localhost:5000

# -----------------------------------------------------------------------------
